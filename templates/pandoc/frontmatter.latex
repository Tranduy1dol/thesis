% Pandoc template for UET thesis frontmatter sections (abstract, acknowledgments, abbreviations)
% Outputs an unnumbered chapter with TOC entry — mirrors the existing cover/*.tex style.

\clearpage
\phantomsection

\addcontentsline{toc}{chapter}{$if(toc-title)$$toc-title$$else$$title$$endif$}
\chapter*{$title$}

$body$

\FloatBarrier
