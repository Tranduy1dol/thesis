% UET Thesis Pandoc LaTeX Template
% Customized for University of Engineering and Technology, VNU

\clearpage
\phantomsection

$if(unnumbered)$
\addcontentsline{toc}{chapter}{$if(toc-title)$$toc-title$$else$$title$$endif$}
\chapter*{$title$}
$else$
$if(chapter)$
\setcounter{chapter}{$chapter$}
\chapter[$if(toc-title)$$toc-title$$else$$title$$endif$]{$title$}
$else$
\chapter{$title$}
$endif$
$endif$

$body$

\FloatBarrier
